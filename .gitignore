# SGIP Monorepo — .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored — it documents required variables

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Prisma — generated client is gitignored (generated during build)
apps/api/src/generated/
apps/api/prisma/generated/

# TypeScript build info
*.tsbuildinfo

# Turbo cache (if added later)
.turbo/

# Project Reference Documents
01-PRD.md
02-Technical-Architecture.md
03-Security-Access-Control.md
04-Frontend-Specification.md
05-Feature-Ticket-List.md
ARCHITECTURE_DECISIONS.md
IMPLEMENTATION_LOG.md
IMPLEMENTATION_STRATEGY.md
KNOWN_ISSUES.md
PROJECT_PROGRESS.md
SESSION_HANDOFF.md
