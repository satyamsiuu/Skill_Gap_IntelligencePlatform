{
  "name": "sgip",
  "version": "0.1.0",
  "description": "Skill Gap Intelligence Platform — production-grade AI-assisted career intelligence system",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' run dev",
    "build": "pnpm --filter './apps/*' run build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "format": "pnpm --recursive run format",
    "format:check": "pnpm --recursive run format:check",
    "clean": "pnpm --recursive run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
