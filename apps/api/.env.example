# SGIP — Environment Variables Reference
# 
# This file documents ALL required environment variables.
# Copy to .env.local (for local dev) and fill in real values.
# NEVER commit .env, .env.local, or any file with real secrets to version control.
#
# For staging/production: use a managed secrets service (e.g., AWS Secrets Manager,
# GCP Secret Manager, Doppler) — not .env files in deployed images.
# Document 2, Section 11 requirement.

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database
# Required: pgvector, pg_trgm, pgcrypto extensions must be enabled (SGIP-1.1.2.1)
# Supported providers: Neon, Supabase, AWS RDS (ensure pgvector support)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sgip_dev?schema=public

# ─────────────────────────────────────────────────────────────────────────────
# Redis (required for BullMQ queues + response caching)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication (RS256 — Document 3, Section 3)
# Generate a key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then set the values as single-line strings with escaped newlines (\n)
# ─────────────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# Cloudinary (file storage — Document 2, Section 9)
# NOTE: Use "raw" resource type for PDF/DOCX uploads (KNOWN_ISSUES.md ISSUE-005)
# ─────────────────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider (Document 2, Section 7.1)
# ─────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────────────────────
# CORS (comma-separated list of allowed origins — no wildcards in production)
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─────────────────────────────────────────────────────────────────────────────
# Email (for verification and notifications)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailhog.local
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@sgip.local

# ─────────────────────────────────────────────────────────────────────────────
# CSRF Protection (Document 3, Section 4.3)
# Generate a strong secret: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
CSRF_SECRET=generate_a_32_char_minimum_random_string_here
